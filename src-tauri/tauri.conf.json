{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Remedy Transcription",
  "version": "1.0.0",
  "identifier": "com.remedy.transcription",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix frontend run dev",
    "beforeBuildCommand": "npm --prefix frontend run build"
  },
  "app": {
    "windows": [
      {
        "title": "Remedy Transcription",
        "label": "main",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$APPLOCALDATA/**",
          "$RESOURCE/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/yt-dlp",
      "binaries/ffmpeg",
      "binaries/ffprobe",
      "binaries/diarize-sidecar"
    ],
    "resources": {
      "../models/diarization/sherpa-onnx-pyannote-segmentation-3-0/model.onnx": "models/diarization/sherpa-onnx-pyannote-segmentation-3-0/model.onnx",
      "../models/diarization/sherpa-onnx-pyannote-segmentation-3-0/LICENSE": "models/diarization/sherpa-onnx-pyannote-segmentation-3-0/LICENSE",
      "../models/diarization/wespeaker_en_voxceleb_CAM++.onnx": "models/diarization/wespeaker_en_voxceleb_CAM++.onnx"
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "Developer ID Application: Quang Phung (7XU3QW326W)",
      "entitlements": "entitlements.plist"
    },
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  }
}
